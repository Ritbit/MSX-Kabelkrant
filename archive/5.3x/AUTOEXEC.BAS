10 A$=CHR$(13)+"Run"+CHR$(34)+"KBLINIT.SYS"+CHR$(13):GOSUB 30
20 BLOAD"RAMDISK.BIN",R
30 POKE &HF3FA,&H00F0:POKE &HF3FB,&H00FB:'Init GETPNT
40 IF LEN(A$)>40 THEN PRINT "Line too long!!":STOP ELSE FOR I=1 TO LEN(A$)
50  POKE &HFBF0+I-1,ASC(MID$(A$,I,1)):'Put string in buffer
60 NEXT
70 WR%=&HFBF0+LEN(A$):POKE &HF3F8,WR% AND 255:POKE &HF3F9,((WR% AND &HFF00)/256) AND 255:'Adjust PUTPNT
80 RETURN
